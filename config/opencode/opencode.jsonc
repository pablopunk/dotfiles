{
  "plugin": [],
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  // === Models ===
  "model": "omniroute/pablo/coding",
  "small_model": "omniroute/pablo/fast",
  "agent": {
    "explore": {
      "model": "omniroute/pablo/fast",
    },
    "compaction": {
      "model": "omniroute/pablo/chat",
    },
    "summary": {
      "model": "omniroute/pablo/fast",
    },
    "build": {
      "model": "omniroute/pablo/coding",
    },
    "plan": {
      "model": "omniroute/pablo/coding",
    },
    "general": {
      "model": "omniroute/pablo/chat",
    },
  },
  // === Permissions ===
  "permission": {
    "external_directory": "allow",
    "bash": {
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny",
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
    "grep.app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true,
    },
  },
  // === Providers ===
  "provider": {
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRoute",
      "options": {
        "baseURL": "https://omniroute.notflix.us/v1",
        "apiKey": "{env:OMNIROUTE_API_KEY}",
      },
      "models": {
        "pablo/coding": {
          "name": "pablo/coding",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "pablo/chat": {
          "name": "pablo/chat",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "pablo/fast": {
          "name": "pablo/fast",
        },
        "auto/best-coding": {
          "name": "auto/best-coding",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/best-reasoning": {
          "name": "auto/best-reasoning",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/best-fast": {
          "name": "auto/best-fast",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/best-vision": {
          "name": "auto/best-vision",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/best-chat": {
          "name": "auto/best-chat",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/best-coding-fast": {
          "name": "auto/best-coding-fast",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/pro-coding": {
          "name": "auto/pro-coding",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/pro-reasoning": {
          "name": "auto/pro-reasoning",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/pro-vision": {
          "name": "auto/pro-vision",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/pro-chat": {
          "name": "auto/pro-chat",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/pro-fast": {
          "name": "auto/pro-fast",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/coding": {
          "name": "auto/coding",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/fast": {
          "name": "auto/fast",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/chat": {
          "name": "auto/chat",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/cheap": {
          "name": "auto/cheap",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/smart": {
          "name": "auto/smart",
          "modalities": {
            "input": ["text", "image"],
