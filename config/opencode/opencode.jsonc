          },
        },
        "auto/vision": {
          "name": "auto/vision",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
  },

  // === Server ===
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
  },
}
