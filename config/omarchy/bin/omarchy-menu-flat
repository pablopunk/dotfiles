#!/bin/bash
# Flat omarchy menu — all leaf actions searchable in one fuzzel prompt.
#
# NOTE: This is a hardcoded flat version of the hierarchical omarchy-menu.
# When omarchy updates with new menu items, run:
#   omarchy-menu-diff
# to see what new items might need to be added here.
#
# The apps list (from .desktop files) is generated dynamically with caching.
#
set -euo pipefail

export PATH="$HOME/.local/share/omarchy/bin:$PATH"

# Cache settings
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omarchy-menu-flat"
CACHE_FILE="$CACHE_DIR/apps.cache"
HISTORY_FILE="$CACHE_DIR/history.txt"
CACHE_MAX_AGE=300  # 5 minutes
HISTORY_MAX_ITEMS=50

# Record a selection to history
record_history() {
    local item="$1"
    [[ -z "$item" ]] && return
    
    # Remove existing entry for this item, then add to top
    local temp=$(mktemp)
    if [[ -f "$HISTORY_FILE" ]]; then
        awk -F'|' -v it="$item" '$2 != it' "$HISTORY_FILE" | tail -n $((HISTORY_MAX_ITEMS - 1)) > "$temp"
    fi
    echo "$(date +%s)|$item" >> "$temp"
    mv "$temp" "$HISTORY_FILE"
}

# Get the recency score for an item (higher = more recent)
get_recency() {
    local item="$1"
    [[ -f "$HISTORY_FILE" ]] || { echo "0"; return; }
    # Extract timestamp for this item, default to 0 if not found
    local ts=$(grep -F "|$item" "$HISTORY_FILE" 2>/dev/null | tail -1 | cut -d'|' -f1)
    echo "${ts:-0}"
}

# Get cache age in seconds
cache_age() {
    [[ -f "$CACHE_FILE" ]] || echo 999999 && return
    local now=$(date +%s)
    local mtime=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || stat -f %m "$CACHE_FILE" 2>/dev/null || echo 0)
    echo $((now - mtime))
}

# Icon mapping for common desktop icons to Nerd Font
icon_for() {
    case "$1" in
        firefox*) echo "" ;;
        chromium*|google-chrome*) echo "" ;;
        code|vscodium) echo "" ;;
        cursor) echo "" ;;
        zed) echo "" ;;
        slack*) echo "" ;;
        discord) echo "" ;;
        telegram*) echo "" ;;
        signal*) echo "" ;;
        spotify) echo "" ;;
        vlc) echo "嗢" ;;
        mpv) echo "" ;;
        obs*) echo "" ;;
        steam*) echo "" ;;
        gimp*) echo "" ;;
        inkscape) echo "" ;;
        blender) echo "" ;;
        krita) echo "" ;;
        alacritty*|gnome-terminal*|konsole*|wezterm*|kitty*|ghostty*) echo "" ;;
        nautilus*|dolphin*|thunar*|pcmanfm*) echo "" ;;
        settings*|gnome-control-center*|system-settings*) echo "" ;;
        1password*|bitwarden*|keepass*) echo "󰟵" ;;
        font*) echo "" ;;
        *) echo "󰀻" ;;
    esac
}

# Generate desktop apps list from .desktop files
generate_apps() {
    # Use cache if fresh
    local age=$(cache_age)
    if [[ $age -lt $CACHE_MAX_AGE && -f "$CACHE_FILE" ]]; then
        cat "$CACHE_FILE"
        return
    fi

    mkdir -p "$CACHE_DIR"
    local temp=$(mktemp)
    
    # Parse .desktop files
    local dirs="/usr/share/applications /usr/local/share/applications $HOME/.local/share/applications $HOME/.local/share/omarchy/applications"
    
    for dir in $dirs; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -f "$file" ]] || continue
            [[ "$file" == */hidden/* ]] && continue
            
            local name="" exec="" icon="" hide="" term=""
            while IFS='=' read -r key val; do
                case "$key" in
                    Name) [[ -z "$name" ]] && name="$val" ;;
                    Exec) [[ -z "$exec" ]] && exec="$val" ;;
                    Icon) [[ -z "$icon" ]] && icon="$val" ;;
                    NoDisplay) [[ "$val" == "true" ]] && hide=1 ;;
                    Terminal) [[ "$val" == "true" ]] && term=1 ;;
                esac
            done < "$file"
            
            [[ -z "$name" || -z "$exec" || "$hide" == 1 ]] && continue
            
            # Clean exec
            exec=$(echo "$exec" | sed 's/ %[fFuUdDnNickvm]//g')
            local icon_char=$(icon_for "$icon")
            
            if [[ "$term" == 1 ]]; then
                echo "$icon_char  $name|terminal $exec"
            else
                echo "$icon_char  $name|uwsm-app -- $exec"
            fi
        done
    done | sort -t'|' -k1,1 -u > "$temp"
    
    mv "$temp" "$CACHE_FILE"
    cat "$CACHE_FILE"
}

# Helpers from omarchy-menu
terminal() { alacritty --class=Omarchy -e "$@"; }
present_terminal() { omarchy-launch-floating-terminal-with-presentation "$1"; }
open_in_editor() { notify-send "Editing config file" "$1"; omarchy-launch-editor "$1"; }
install() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2"; }
install_and_launch() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2 && setsid gtk-launch $3"; }
install_font() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm --needed $2 && sleep 2 && omarchy-font-set '$3'"; }
install_terminal() { present_terminal "omarchy-install-terminal $1"; }
aur_install() { present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2"; }
aur_install_and_launch() { present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2 && setsid gtk-launch $3"; }

