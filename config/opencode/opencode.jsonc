{
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  // === Models ===
  "model": "omniroute/pablo/coding",
  "small_model": "omniroute/pablo/fast",
  "agent": {
    "explore": {
      "model": "omniroute/pablo/fast"
    },
    "compaction": {
      "model": "omniroute/pablo/chat"
    },
    "summary": {
      "model": "omniroute/pablo/fast"
    },
    "build": {
      "model": "omniroute/pablo/coding"
    },
    "plan": {
      "model": "omniroute/pablo/coding"
    },
    "general": {
      "model": "omniroute/pablo/chat"
    }
  },
  // === Permissions ===
  "permission": {
    "external_directory": "allow",
    "bash": {
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "grep.app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    }
  },
  // === Providers ===
  "provider": {
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRoute",
      "options": {
        "baseURL": "https://omniroute.notflix.us/v1",
        "apiKey": "{env:OMNIROUTE_API_KEY}"
      },
      "models": {
        "pablo/coding": {
          "name": "pablo/coding"
        },
        "pablo/fast": {
          "name": "pablo/fast"
        },
        "pablo/chat": {
          "name": "pablo/chat"
        }
      }
    }
  },

  // === Server ===
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  }
}
