#!/bin/bash
# Dynamic flat menu - parses omarchy-menu at runtime with caching

set -euo pipefail

export PATH="$HOME/.local/share/omarchy/bin:$PATH"

OMARCHY_MENU="${OMARCHY_MENU:-$HOME/.local/share/omarchy/bin/omarchy-menu}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omarchy-menu-flat"
FLAT_CACHE="$CACHE_DIR/flat.cache"
APPS_CACHE="$CACHE_DIR/apps.cache"
HISTORY_FILE="$CACHE_DIR/history.txt"
CACHE_MAX_AGE=3600
APPS_MAX_AGE=300
HISTORY_MAX_ITEMS=50

terminal() { alacritty --class=Omarchy -e "$@"; }
present_terminal() { omarchy-launch-floating-terminal-with-presentation "$1"; }
open_in_editor() { notify-send "Editing config file" "$1"; omarchy-launch-editor "$1"; }

parse_omarchy_menu() {
    [[ -f "$OMARCHY_MENU" ]] || { echo "Error: omarchy-menu not found" >&2; exit 1; }
    
    # Use sed/awk to extract menu structure
    grep -E '^\*[^*]+\*\)' "$OMARCHY_MENU" | \
    sed 's/^\s*\*//;s/\*)$//' | \
    while read -r label; do
        # Skip navigation items
        [[ "$label" =~ (Back|Exit|Close) ]] && continue
        echo "$label"
    done | sort -u
}

cache_age() {
    local file="$1"
    [[ -f "$file" ]] || { echo 999999; return; }
    local now=$(date +%s)
    local mtime=$(stat -c %Y "$file" 2>/dev/null || stat -f %m "$file" 2>/dev/null || echo 0)
    echo $((now - mtime))
}

get_flat_items() {
    if [[ $(cache_age "$FLAT_CACHE") -lt $CACHE_MAX_AGE && -f "$FLAT_CACHE" ]]; then
        cat "$FLAT_CACHE"
    else
        mkdir -p "$CACHE_DIR"
        parse_omarchy_menu > "$FLAT_CACHE"
        cat "$FLAT_CACHE"
    fi
}

generate_apps() {
    if [[ $(cache_age "$APPS_CACHE") -lt $APPS_MAX_AGE && -f "$APPS_CACHE" ]]; then
        cat "$APPS_CACHE"
        return
    fi
    
    local dirs="/usr/share/applications /usr/local/share/applications $HOME/.local/share/applications $HOME/.local/share/omarchy/applications"
    local temp=$(mktemp)
    
    for dir in $dirs; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -f "$file" ]] || continue
            [[ "$file" == */hidden/* ]] && continue
            
            local name="" exec="" hide="" term=""
            while IFS='=' read -r key val; do
                case "$key" in
                    Name) [[ -z "$name" ]] && name="$val" ;;
                    Exec) [[ -z "$exec" ]] && exec="$val" ;;
                    NoDisplay) [[ "$val" == "true" ]] && hide=1 ;;
                    Terminal) [[ "$val" == "true" ]] && term=1 ;;
                esac
            done < "$file"
            
            [[ -z "$name" || -z "$exec" || "$hide" == 1 ]] && continue
            exec=$(echo "$exec" | sed 's/ %[fFuUdDnNickvm]//g')
            
            if [[ "$term" == 1 ]]; then
                echo "$name|APP:$exec:term"
            else
                echo "$name|APP:$exec:gui"
            fi
        done
    done | sort -t'|' -k1,1 -u > "$temp"
    
    mv "$temp" "$APPS_CACHE"
    cat "$APPS_CACHE"
}

record_history() {
    local item="$1"
    [[ -z "$item" ]] && return
    local temp=$(mktemp)
    if [[ -f "$HISTORY_FILE" ]]; then
        awk -F'|' -v it="$item" '$2 != it' "$HISTORY_FILE" | tail -n $((HISTORY_MAX_ITEMS - 1)) > "$temp"
    fi
    echo "$(date +%s)|$item" >> "$temp"
    mv "$temp" "$HISTORY_FILE"
}

mkdir -p "$CACHE_DIR"

declare -a ALL_ITEMS
ALL_ITEMS+=("(Browse all apps...)|LAUNCH_FUZZEL")

while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ALL_ITEMS+=("$name|ACTION:$cmd")
done < <(get_flat_items)

while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ALL_ITEMS+=("$name|$cmd")
done < <(generate_apps)

PIDFILE="$CACHE_DIR/menu.pid"
if [[ -f "$PIDFILE" ]]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null)
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
        if grep -q "Search all" /proc/$oldpid/cmdline 2>/dev/null; then
            kill "$oldpid" 2>/dev/null
            rm -f "$PIDFILE"
            exit 0
        fi
    fi
fi

declare -a SORTED_ITEMS
declare -A SEEN

if [[ -f "$HISTORY_FILE" ]]; then
    while IFS='|' read -r ts item; do
        [[ -n "$item" ]] || continue
        for full_item in "${ALL_ITEMS[@]}"; do
            if [[ "${full_item%%|*}" == "$item" ]]; then
                if [[ -z "${SEEN[$item]:-}" ]]; then
                    SORTED_ITEMS+=("$full_item")
                    SEEN["$item"]=1
                fi
                break
            fi
        done
    done < <(tac "$HISTORY_FILE" 2>/dev/null)
fi

for full_item in "${ALL_ITEMS[@]}"; do
    item_name="${full_item%%|*}"
    if [[ -z "${SEEN[$item_name]:-}" ]]; then
        SORTED_ITEMS+=("$full_item")
    fi
done

choice=$(printf '%s\n' "${SORTED_ITEMS[@]}" | cut -d'|' -f1 | fuzzel --dmenu --width 35 --placeholder "Search all..." &
fuzzel_pid=$!
echo $fuzzel_pid > "$PIDFILE"
wait $fuzzel_pid 2>/dev/null
rm -f "$PIDFILE"
choice=$(cat "$CACHE_DIR/choice.tmp" 2>/dev/null || true)
rm -f "$CACHE_DIR/choice.tmp"

[[ -z "$choice" || "$choice" == "CNCLD" ]] && exit 0

record_history "$choice"

for item in "${SORTED_ITEMS[@]}"; do
    if [[ "${item%%|*}" == "$choice" ]]; then
        cmd="${item#*|}"
        
        if [[ "$cmd" == APP:* ]]; then
            exec_type=$(echo "$cmd" | cut -d: -f3)
            app_cmd=$(echo "$cmd" | cut -d: -f2)
            if [[ "$exec_type" == "term" ]]; then
                terminal $app_cmd
            else
                uwsm-app -- $app_cmd
            fi
            exit 0
        fi
        
        if [[ "$cmd" == "LAUNCH_FUZZEL" ]]; then
            rm -f "$APPS_CACHE"
            generate_apps > /dev/null 2>&1
            fuzzel
            exit 0
        fi
        
        if [[ "$cmd" == ACTION:* ]]; then
            action_cmd="${cmd#ACTION:}"
            # Map label to actual command - this is the challenge
            # For now, just show what was selected
            notify-send "Menu" "Selected: $choice"
        fi
        
        exit 0
    fi
done
