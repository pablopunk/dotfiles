#!/bin/bash
# Dynamic flat menu - parses omarchy-menu at runtime with caching
# Rebuilds flat menu structure from hierarchical omarchy-menu automatically
#
# When omarchy updates, delete the cache to rebuild:
#   rm ~/.cache/omarchy-menu-flat/flat.cache

set -euo pipefail

export PATH="$HOME/.local/share/omarchy/bin:$PATH"

OMARCHY_MENU="${OMARCHY_MENU:-$HOME/.local/share/omarchy/bin/omarchy-menu}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omarchy-menu-flat"
FLAT_CACHE="$CACHE_DIR/flat.cache"
APPS_CACHE="$CACHE_DIR/apps.cache"
HISTORY_FILE="$CACHE_DIR/history.txt"
CACHE_MAX_AGE=3600  # 1 hour for menu structure
APPS_MAX_AGE=300    # 5 minutes for apps
HISTORY_MAX_ITEMS=50

# Terminal helper
terminal() { alacritty --class=Omarchy -e "$@"; }
present_terminal() { omarchy-launch-floating-terminal-with-presentation "$1"; }
open_in_editor() { notify-send "Editing config file" "$1"; omarchy-launch-editor "$1"; }
install() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2"; }
install_and_launch() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2 && setsid gtk-launch $3"; }
install_font() { present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm --needed $2 && sleep 2 && omarchy-font-set '$3'"; }
install_terminal() { present_terminal "omarchy-install-terminal $1"; }
aur_install() { present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2"; }
aur_install_and_launch() { present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2 && setsid gtk-launch $3"; }

# Parse omarchy-menu and extract flat menu items
parse_omarchy_menu() {
    [[ -f "$OMARCHY_MENU" ]] || { echo "Error: omarchy-menu not found at $OMARCHY_MENU" >&2; exit 1; }
    
    # Extract all menu items from show_*_menu functions
    # Format: ICON  Category › Item|COMMAND
    awk '
    BEGIN { category=""; icon=""; }
    
    # Track which function we are in
    /^show_([a-z_]+)_menu\(\)/ {
        match($0, /show_([a-z_]+)_menu/, m)
        func = m[1]
        # Map function names to categories and icons
        if (func == "main") { category=""; icon=""; }
        else if (func == "system") { category="System"; icon=""; }
        else if (func == "learn") { category="Learn"; icon="󰧑"; }
        else if (func == "trigger") { category="Trigger"; icon="󱓞"; }
        else if (func == "capture") { category="Capture"; icon=""; }
        else if (func == "share") { category="Share"; icon=""; }
        else if (func == "toggle") { category="Toggle"; icon="󰔎"; }
        else if (func == "style") { category="Style"; icon=""; }
        else if (func == "setup") { category="Setup"; icon=""; }
        else if (func == "install") { category="Install"; icon="󰉉"; }
        else if (func == "remove") { category="Remove"; icon="󰭌"; }
        else if (func == "update") { category="Update"; icon=""; }
        else { category=func; gsub(/_/, " ", category); icon="󰀻"; }
    }
    
    # Extract menu options from case statements
    /^\s+\*[^\*]+\*\)/ {
        # Extract the label between * and *)
        match($0, /\*([^)]+)\*\)/, m)
        label = m[1]
        
        # Skip navigation items
        if (label ~ /Back|Exit|Close/) next
        
        # Get the command from the next line
        getline cmd_line
        gsub(/^\s+/, "", cmd_line)
        
        # Extract the command (before ;;)
        cmd = cmd_line
        sub(/;;.*$/, "", cmd)
        
        # Format output
        if (category == "") {
            printf "%s  %s|%s\n", icon, label, cmd
        } else {
            printf "%s  %s › %s|%s\n", icon, category, label, cmd
        }
    }
    ' "$OMARCHY_MENU" 2>/dev/null | sort -t'|' -k1,1 -u
}

# Cache age check
cache_age() {
    local file="$1"
    [[ -f "$file" ]] || { echo 999999; return; }
    local now=$(date +%s)
    local mtime=$(stat -c %Y "$file" 2>/dev/null || stat -f %m "$file" 2>/dev/null || echo 0)
    echo $((now - mtime))
}

# Get or build flat menu items
get_flat_items() {
    if [[ $(cache_age "$FLAT_CACHE") -lt $CACHE_MAX_AGE && -f "$FLAT_CACHE" ]]; then
        cat "$FLAT_CACHE"
    else
        mkdir -p "$CACHE_DIR"
        parse_omarchy_menu > "$FLAT_CACHE"
        cat "$FLAT_CACHE"
    fi
}

# Icon mapping for apps
icon_for_app() {
    case "$1" in
        firefox*) echo "" ;;
        chromium*|google-chrome*) echo "" ;;
        code|vscodium) echo "" ;;
        cursor) echo "" ;;
        zed) echo "" ;;
        slack*) echo "" ;;
        discord) echo "" ;;
        telegram*) echo "" ;;
        signal*) echo "" ;;
        spotify) echo "" ;;
        vlc) echo "嗢" ;;
        mpv) echo "" ;;
        obs*) echo "" ;;
        steam*) echo "" ;;
        gimp*) echo "" ;;
        inkscape) echo "" ;;
        blender) echo "" ;;
        krita) echo "" ;;
        alacritty*|gnome-terminal*|konsole*|wezterm*|kitty*|ghostty*) echo "" ;;
        nautilus*|dolphin*|thunar*|pcmanfm*) echo "" ;;
        settings*|gnome-control-center*|system-settings*) echo "" ;;
        1password*|bitwarden*|keepass*) echo "󰟵" ;;
        font*) echo "" ;;
        *) echo "󰀻" ;;
    esac
}

# Generate apps list
generate_apps() {
    if [[ $(cache_age "$APPS_CACHE") -lt $APPS_MAX_AGE && -f "$APPS_CACHE" ]]; then
        cat "$APPS_CACHE"
        return
    fi
    
    local dirs="/usr/share/applications /usr/local/share/applications $HOME/.local/share/applications $HOME/.local/share/omarchy/applications"
    local temp=$(mktemp)
    
    for dir in $dirs; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -f "$file" ]] || continue
            [[ "$file" == */hidden/* ]] && continue
            
            local name="" exec="" icon="" hide="" term=""
            while IFS='=' read -r key val; do
                case "$key" in
                    Name) [[ -z "$name" ]] && name="$val" ;;
                    Exec) [[ -z "$exec" ]] && exec="$val" ;;
                    Icon) [[ -z "$icon" ]] && icon="$val" ;;
                    NoDisplay) [[ "$val" == "true" ]] && hide=1 ;;
                    Terminal) [[ "$val" == "true" ]] && term=1 ;;
                esac
            done < "$file"
            
            [[ -z "$name" || -z "$exec" || "$hide" == 1 ]] && continue
            exec=$(echo "$exec" | sed 's/ %[fFuUdDnNickvm]//g')
            local icon_char=$(icon_for_app "$icon")
            
            if [[ "$term" == 1 ]]; then
                echo "$icon_char  $name|APP:$exec:term"
            else
                echo "$icon_char  $name|APP:$exec:gui"
            fi
        done
    done | sort -t'|' -k1,1 -u > "$temp"
    
    mv "$temp" "$APPS_CACHE"
    cat "$APPS_CACHE"
}

# Record history
record_history() {
    local item="$1"
    [[ -z "$item" ]] && return
    local temp=$(mktemp)
    if [[ -f "$HISTORY_FILE" ]]; then
        awk -F'|' -v it="$item" '$2 != it' "$HISTORY_FILE" | tail -n $((HISTORY_MAX_ITEMS - 1)) > "$temp"
    fi
    echo "$(date +%s)|$item" >> "$temp"
    mv "$temp" "$HISTORY_FILE"
}

# Refresh apps and launch fuzzel
refresh_apps_and_launch_fuzzel() {
    rm -f "$APPS_CACHE"
    generate_apps > /dev/null 2>&1
    fuzzel
}

# --- MAIN ---

mkdir -p "$CACHE_DIR"

# Build items list
declare -a ALL_ITEMS

# Add special items
ALL_ITEMS+=("󰀻  (Browse all apps...)|refresh_apps_and_launch_fuzzel")

# Add parsed omarchy menu items
while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ALL_ITEMS+=("$name|$cmd")
done < <(get_flat_items)

# Add apps
while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ALL_ITEMS+=("$name|$cmd")
done < <(generate_apps)

# Toggle logic
PIDFILE="$CACHE_DIR/menu.pid"
if [[ -f "$PIDFILE" ]]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null)
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
        if grep -q "Search all" /proc/$oldpid/cmdline 2>/dev/null; then
            kill "$oldpid" 2>/dev/null
            rm -f "$PIDFILE"
            exit 0
        fi
    fi
fi

# Sort by recency
declare -a SORTED_ITEMS
declare -A SEEN

if [[ -f "$HISTORY_FILE" ]]; then
    while IFS='|' read -r ts item; do
        [[ -n "$item" ]] || continue
        for full_item in "${ALL_ITEMS[@]}"; do
            if [[ "${full_item%%|*}" == "$item" ]]; then
                if [[ -z "${SEEN[$item]:-}" ]]; then
                    SORTED_ITEMS+=("$full_item")
                    SEEN["$item"]=1
                fi
                break
            fi
        done
    done < <(tac "$HISTORY_FILE" 2>/dev/null)
fi

for full_item in "${ALL_ITEMS[@]}"; do
    item_name="${full_item%%|*}"
    if [[ -z "${SEEN[$item_name]:-}" ]]; then
        SORTED_ITEMS+=("$full_item")
    fi
done

# Show fuzzel
choice=$(printf '%s\n' "${SORTED_ITEMS[@]}" | cut -d'|' -f1 | fuzzel --dmenu --width 35 --placeholder "Search all..." &
fuzzel_pid=$!
echo $fuzzel_pid > "$PIDFILE"
wait $fuzzel_pid 2>/dev/null
rm -f "$PIDFILE"
choice=$(cat "$CACHE_DIR/choice.tmp" 2>/dev/null || true)
rm -f "$CACHE_DIR/choice.tmp"

[[ -z "$choice" || "$choice" == "CNCLD" ]] && exit 0

record_history "$choice"

# Find and execute command
for item in "${SORTED_ITEMS[@]}"; do
    if [[ "${item%%|*}" == "$choice" ]]; then
        cmd="${item#*|}"
        
        # Handle app launches
        if [[ "$cmd" == APP:* ]]; then
            exec_type=$(echo "$cmd" | cut -d: -f3)
            app_cmd=$(echo "$cmd" | cut -d: -f2)
            if [[ "$exec_type" == "term" ]]; then
                terminal $app_cmd
            else
                uwsm-app -- $app_cmd
            fi
            exit 0
        fi
        
        # Handle special functions
        if [[ "$cmd" == "refresh_apps_and_launch_fuzzel" ]]; then
            refresh_apps_and_launch_fuzzel
            exit 0
        fi
        
        # Handle omarchy commands
        eval "$cmd"
        exit 0
    fi
done
