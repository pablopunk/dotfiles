            "output": ["text"],
          },
        },
        "auto/coding:free": {
          "name": "auto/coding:free",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "auto/coding:pro": {
          "name": "auto/coding:pro",
          "modalities": {
            "input": ["text", "image"],
