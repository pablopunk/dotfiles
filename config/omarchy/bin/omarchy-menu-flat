#!/bin/bash
# Flat omarchy menu - all items searchable in one list with icons
# Features: recent-first ordering, toggle with Super+Space
set -euo pipefail
export PATH="$HOME/.local/bin:$HOME/.local/share/omarchy/bin:$PATH"

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omarchy-menu-flat"
APPS_CACHE="$CACHE_DIR/apps.cache"
HISTORY_FILE="$CACHE_DIR/history.txt"
CACHE_MAX_AGE=300
HISTORY_MAX_ITEMS=50
mkdir -p "$CACHE_DIR"

terminal() { alacritty --class=Omarchy -e "$@"; }
present_terminal() { omarchy-launch-floating-terminal-with-presentation "$1"; }
run_shell() { bash -lc "$1"; }

require_fuzzel() {
    if ! command -v fuzzel >/dev/null 2>&1; then
        notify-send "Omarchy menu" "Install fuzzel before using this utility. Try: pacman -S fuzzel"
        echo "fuzzel not found; please install 'fuzzel'." >&2
        exit 127
    fi
}

fuzzel_theme_ready() {
    local main_conf theme_include
    main_conf="${XDG_CONFIG_HOME:-$HOME/.config}/fuzzel/fuzzel.ini"
    [[ -f "$main_conf" ]] || return 0
    theme_include=$(awk -F'= *' '/^[[:space:]]*include[[:space:]]*=/{print $2; exit}' "$main_conf" | sed 's/[[:space:]]*$//')
    [[ -z "$theme_include" ]] && return 0
    theme_include="${theme_include/#\~/$HOME}"
    [[ -f "$theme_include" ]]
}

ensure_fuzzel_ready() {
    require_fuzzel
    if ! fuzzel_theme_ready; then
        notify-send "Omarchy menu" "Missing fuzzel theme include. Try reapplying Omarchy/dotfiles."
        echo "Missing fuzzel theme include referenced by ~/.config/fuzzel/fuzzel.ini" >&2
        exit 1
    fi
}

add_item() {
    local label="$1" kind="$2" payload="$3"
    ITEMS+=("$label|$kind|$payload")
}

# Record selection to history
record_history() {
    local item="$1"
    [[ -z "$item" ]] && return
    local temp=$(mktemp)
    if [[ -f "$HISTORY_FILE" ]]; then
        awk -F'|' -v it="$item" '$2 != it' "$HISTORY_FILE" | tail -n $((HISTORY_MAX_ITEMS - 1)) > "$temp"
    fi
    echo "$(date +%s)|$item" >> "$temp"
    mv "$temp" "$HISTORY_FILE"
}

# Build flat items list with icons
declare -a ITEMS

