ACTIONS["  About"]='omarchy-launch-about'

# Apps - flat list with generic icons + option to browse all with real icons
ACTIONS["󰀻  (Browse all apps...)"]='fuzzel'

# Build the list: ACTIONS + generated desktop apps
declare -a ALL_ITEMS
for key in "${!ACTIONS[@]}"; do
    ALL_ITEMS+=("$key|${ACTIONS[$key]}")
done

# Add desktop apps (with generic Nerd Font icons)
while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ALL_ITEMS+=("$name|$cmd")
done < <(generate_apps)

# Toggle: if fuzzel is already running with our menu, kill it
PIDFILE="$CACHE_DIR/menu.pid"
if [[ -f "$PIDFILE" ]]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null)
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
        # Check it's actually our fuzzel (not some other instance)
        if grep -q "Search all" /proc/$oldpid/cmdline 2>/dev/null; then
            kill "$oldpid" 2>/dev/null
            rm -f "$PIDFILE"
            exit 0
        fi
    fi
fi

# Sort by recency: build list with history first, then remaining items alphabetically
declare -a SORTED_ITEMS
declare -A SEEN

# First, add items from history (most recent first)
if [[ -f "$HISTORY_FILE" ]]; then
    # Read history in reverse (most recent last in file = most recent first)
    tac "$HISTORY_FILE" 2>/dev/null | while IFS='|' read -r ts item; do
        [[ -n "$item" ]] || continue
        # Find this item in ALL_ITEMS
        for full_item in "${ALL_ITEMS[@]}"; do
            if [[ "${full_item%%|*}" == "$item" ]]; then
                if [[ -z "${SEEN[$item]:-}" ]]; then
                    echo "$full_item"
                    SEEN["$item"]=1
                fi
                break
            fi
        done
    done > "$CACHE_DIR/sorted.tmp"
fi

# Add remaining items alphabetically
for full_item in "${ALL_ITEMS[@]}"; do
    item_name="${full_item%%|*}"
    if [[ -z "${SEEN[$item_name]:-}" ]]; then
        echo "$full_item" >> "$CACHE_DIR/sorted.tmp"
    fi
done

# Read sorted items
while IFS= read -r line; do
    [[ -n "$line" ]] && SORTED_ITEMS+=("$line")
done < "$CACHE_DIR/sorted.tmp"
rm -f "$CACHE_DIR/sorted.tmp"

# Show fuzzel with combined list - run in background so we can toggle-kill it
printf '%s\n' "${SORTED_ITEMS[@]}" | cut -d'|' -f1 | fuzzel --dmenu --width 35 --placeholder "Search all..." > "$CACHE_DIR/choice.tmp" &
fuzzel_pid=$!
echo $fuzzel_pid > "$PIDFILE"
wait $fuzzel_pid 2>/dev/null
rm -f "$PIDFILE"
choice=$(cat "$CACHE_DIR/choice.tmp" 2>/dev/null || true)
rm -f "$CACHE_DIR/choice.tmp"

[[ -z "$choice" || "$choice" == "CNCLD" ]] && exit 0

# Record selection to history
record_history "$choice"

# Find command for selected item
for item in "${SORTED_ITEMS[@]}"; do
    if [[ "${item%%|*}" == "$choice" ]]; then
        cmd="${item#*|}"
        eval "$cmd"
        exit 0
    fi
done
