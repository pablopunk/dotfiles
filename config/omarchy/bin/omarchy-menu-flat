#!/bin/bash
# Flat omarchy menu - all items searchable in one list with icons
# Features: recent-first ordering, toggle with Super+Space
set -euo pipefail
export PATH="$HOME/.local/share/omarchy/bin:$PATH"

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/omarchy-menu-flat"
APPS_CACHE="$CACHE_DIR/apps.cache"
HISTORY_FILE="$CACHE_DIR/history.txt"
CACHE_MAX_AGE=300
HISTORY_MAX_ITEMS=50
mkdir -p "$CACHE_DIR"

terminal() { alacritty --class=Omarchy -e "$@"; }
present_terminal() { omarchy-launch-floating-terminal-with-presentation "$1"; }

# Record selection to history
record_history() {
    local item="$1"
    [[ -z "$item" ]] && return
    local temp=$(mktemp)
    if [[ -f "$HISTORY_FILE" ]]; then
        awk -F'|' -v it="$item" '$2 != it' "$HISTORY_FILE" | tail -n $((HISTORY_MAX_ITEMS - 1)) > "$temp"
    fi
    echo "$(date +%s)|$item" >> "$temp"
    mv "$temp" "$HISTORY_FILE"
}

# Build flat items list with icons
declare -a ITEMS

# System
ITEMS+=("’ĆŻ Lock|omarchy-lock-screen")
ITEMS+=("¾▒ää Screensaver|omarchy-launch-screensaver force")
ITEMS+=("¾░żä Suspend|systemctl suspend")
ITEMS+=("’ŹÖ Relaunch|uwsm stop")
ITEMS+=("¾░£ē Restart|systemctl reboot")
ITEMS+=("¾░Éź Shutdown|systemctl poweroff")

# Learn
ITEMS+=("¾░īī Keybindings|omarchy-menu-keybindings")
ITEMS+=("’Éģ Omarchy Manual|omarchy-launch-webapp https://learn.omacom.io/2/the-omarchy-manual")
ITEMS+=("’ŹÖ Hyprland Wiki|omarchy-launch-webapp https://wiki.hypr.land/")
ITEMS+=("¾░Żć Arch Wiki|omarchy-launch-webapp https://wiki.archlinux.org/title/Main_page")
ITEMS+=("ŅÜ« Neovim Keymaps|omarchy-launch-webapp https://www.lazyvim.org/keymaps")
ITEMS+=("¾▒åā Bash Cheatsheet|omarchy-launch-webapp https://devhints.io/bash")

# Capture
ITEMS+=("’Ć░ Screenshot Region|omarchy-cmd-screenshot")
ITEMS+=("’Ć░ Screenshot Window|omarchy-cmd-screenshot window")
ITEMS+=("’Ć░ Screenshot Display|omarchy-cmd-screenshot output")
ITEMS+=("’ĆĮ Screenrecord Region|omarchy-cmd-screenrecord")
ITEMS+=("’ĆĮ Screenrecord Region + Audio|omarchy-cmd-screenrecord region audio")
ITEMS+=("’ĆĮ Screenrecord Display|omarchy-cmd-screenrecord output")
ITEMS+=("’ĆĮ Screenrecord Display + Audio|omarchy-cmd-screenrecord output audio")
ITEMS+=("¾░āē Color Picker|pkill hyprpicker || hyprpicker -a")

# Share
ITEMS+=("’ü┐ Share Clipboard|terminal bash -c omarchy-cmd-share clipboard")
ITEMS+=("Ņ®╗ Share File|terminal bash -c omarchy-cmd-share file")
ITEMS+=("’äö Share Folder|terminal bash -c omarchy-cmd-share folder")

# Toggle
ITEMS+=("¾▒ää Toggle Screensaver|omarchy-toggle-screensaver")
ITEMS+=("¾░öÄ Toggle Nightlight|omarchy-toggle-nightlight")
ITEMS+=("¾▒½¢ Toggle Idle Lock|omarchy-toggle-idle")
ITEMS+=("¾░Ź£ Toggle Top Bar|omarchy-toggle-waybar")

# Style
ITEMS+=("¾░Ėī Theme|omarchy-menu theme")
ITEMS+=("ŅÖÖ Font|omarchy-menu font")
ITEMS+=("’ĆŠ Background|omarchy-menu background")

# Setup
ITEMS+=("ŅśĖ Audio|\$TERMINAL --class=Wiremix -e wiremix")
ITEMS+=("’ć½ Wifi|rfkill unblock wifi; omarchy-launch-wifi")
ITEMS+=("¾░é» Bluetooth|rfkill unblock bluetooth; blueberry")

# Install
ITEMS+=("¾░Żć Install Package|terminal omarchy-pkg-install")
ITEMS+=("¾░Żć Install AUR|terminal omarchy-pkg-aur-install")
ITEMS+=("’Æć Install AppImage|terminal omarchy-appimage-install")
ITEMS+=("’ē© Install Web App|present_terminal omarchy-webapp-install")
ITEMS+=("’Æē Install TUI|present_terminal omarchy-tui-install")
ITEMS+=("ŅŻÜ Install VSCode|present_terminal yay -S --noconfirm visual-studio-code-bin")
ITEMS+=("’ģ£ Install Cursor|present_terminal yay -S --noconfirm cursor-bin")
ITEMS+=("’ģ£ Install Zed|present_terminal sudo pacman -S --noconfirm zed")

# Remove
ITEMS+=("¾░Łī Remove Package|terminal omarchy-pkg-remove")
ITEMS+=("’ē© Remove Web App|present_terminal omarchy-webapp-remove")
ITEMS+=("’Æē Remove TUI|present_terminal omarchy-tui-remove")
ITEMS+=("¾░Ėī Remove Theme|present_terminal omarchy-theme-remove")
ITEMS+=("¾░łĘ Remove Fingerprint|present_terminal omarchy-setup-fingerprint --remove")
ITEMS+=("Ņ¼æ Remove Fido2|present_terminal omarchy-setup-fido2 --remove")

# Update
ITEMS+=("’ĆĪ Update Omarchy|present_terminal omarchy-update")
ITEMS+=("Ņ®Ė Update Firmware|present_terminal omarchy-update-firmware")
ITEMS+=("Ņ¼ü Update Timezone|present_terminal omarchy-tz-select")
ITEMS+=("ŅÄā Update Time|present_terminal omarchy-update-time")

# About
ITEMS+=("Ņ®┤ About|omarchy-launch-about")

# Apps
ITEMS+=("¾░Ć╗ (Browse all apps...)|FUZZEL")

# Icon for apps based on desktop file icon name
icon_for_app() {
    case "$1" in
        firefox*) echo "’ē®" ;;
        chromium*|google-chrome*|chrome) echo "’ē©" ;;
        code*|vscodium) echo "ŅŻÜ" ;;
        cursor) echo "’ģ£" ;;
        zed) echo "’ģ£" ;;
        slack*) echo "’åś" ;;
        discord) echo "’ć┐" ;;
        telegram*) echo "’ŗå" ;;
        signal*) echo "’üĄ" ;;
        spotify) echo "’å╝" ;;
        vlc) echo "’®╗" ;;
        mpv) echo "’ĆĮ" ;;
        obs*) echo "’ĆĮ" ;;
        steam*) echo "’åČ" ;;
        gimp*) echo "’ć╝" ;;
        inkscape) echo "’ī╗" ;;
        blender) echo "’¢¬" ;;
        krita) echo "’ć╝" ;;
        alacritty*|gnome-terminal*|konsole*|wezterm*|kitty*|ghostty*) echo "’Æē" ;;
        nautilus*|dolphin*|thunar*|pcmanfm*|files) echo "’ü╝" ;;
        settings*|gnome-control-center*|system-settings*) echo "ŅśĢ" ;;
        1password*|bitwarden*|keepass*|password*) echo "¾░¤Ą" ;;
        font*) echo "ŅÖÖ" ;;
        *) echo "¾░Ć╗" ;;
    esac
}

# Generate apps with icons (cached)
generate_apps() {
    if [[ -f "$APPS_CACHE" ]]; then
        local mtime age
        mtime=$(stat -c %Y "$APPS_CACHE" 2>/dev/null || stat -f %m "$APPS_CACHE" 2>/dev/null || echo 0)
        age=$(($(date +%s) - mtime))
        [[ $age -lt $CACHE_MAX_AGE ]] && { cat "$APPS_CACHE"; return; }
    fi
    
    local dirs="/usr/share/applications /usr/local/share/applications $HOME/.local/share/applications $HOME/.local/share/omarchy/applications"
    local temp
    temp=$(mktemp)
    for dir in $dirs; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -f "$file" ]] || continue
            [[ "$file" == */hidden/* ]] && continue
            local name="" exec="" icon="" hide="" term=""
            while IFS='=' read -r key val; do
                case "$key" in
                    Name) [[ -z "$name" ]] && name="$val" ;;
                    Exec) [[ -z "$exec" ]] && exec="$val" ;;
                    Icon) [[ -z "$icon" ]] && icon="$val" ;;
                    NoDisplay) [[ "$val" == "true" ]] && hide=1 ;;
                    Terminal) [[ "$val" == "true" ]] && term=1 ;;
                esac
            done < "$file"
            [[ -z "$name" || -z "$exec" || "$hide" == 1 ]] && continue
            exec=$(echo "$exec" | sed 's/ %[fFuUdDnNickvm]//g' | sed 's/^"//;s/"$//')
            local icon_char
            icon_char=$(icon_for_app "$icon")
            if [[ "$term" == 1 ]]; then
                echo "$icon_char $name|TERM:$exec"
            else
                echo "$icon_char $name|GUI:$exec"
            fi
        done
    done | sort -t'|' -k1,1 -u > "$temp"
    mv "$temp" "$APPS_CACHE"
    cat "$APPS_CACHE"
}

# Add apps to ITEMS
while IFS='|' read -r name cmd; do
    [[ -n "$name" ]] && ITEMS+=("$name|$cmd")
done < <(generate_apps)

# Toggle: if menu is already open, close it
PIDFILE="$CACHE_DIR/menu.pid"
if [[ -f "$PIDFILE" ]]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null)
    if [[ -n "$oldpid" ]] && kill -0 "$oldpid" 2>/dev/null; then
        # Kill the fuzzel process and our script will exit too
        kill "$oldpid" 2>/dev/null
        rm -f "$PIDFILE"
        exit 0
    fi
    # Stale pid file
    rm -f "$PIDFILE"
fi

# Sort by recency: history first, then remaining items
declare -a SORTED_ITEMS
declare -A SEEN

if [[ -f "$HISTORY_FILE" ]]; then
    while IFS='|' read -r ts item; do
        [[ -n "$item" ]] || continue
        for full_item in "${ITEMS[@]}"; do
            if [[ "${full_item%%|*}" == "$item" ]]; then
                if [[ -z "${SEEN[$item]:-}" ]]; then
                    SORTED_ITEMS+=("$full_item")
                    SEEN["$item"]=1
                fi
                break
            fi
        done
    done < <(tac "$HISTORY_FILE" 2>/dev/null)
fi

for full_item in "${ITEMS[@]}"; do
    item_name="${full_item%%|*}"
    if [[ -z "${SEEN[$item_name]:-}" ]]; then
        SORTED_ITEMS+=("$full_item")
    fi
done

# Show menu - run fuzzel in background
choice_file=$(mktemp)
printf '%s\n' "${SORTED_ITEMS[@]}" | cut -d'|' -f1 > "$CACHE_DIR/menu_items.txt"
fuzzel --dmenu --width 35 --placeholder "Search all..." < "$CACHE_DIR/menu_items.txt" > "$choice_file" &
fuzzel_pid=$!
echo $fuzzel_pid > "$PIDFILE"
wait $fuzzel_pid 2>/dev/null
rm -f "$PIDFILE" "$CACHE_DIR/menu_items.txt"

choice=$(cat "$choice_file" 2>/dev/null || true)
rm -f "$choice_file"

[[ -z "$choice" ]] && exit 0

record_history "$choice"

# Find and execute
for item in "${SORTED_ITEMS[@]}"; do
    name="${item%%|*}"
    cmd="${item#*|}"
    if [[ "$name" == "$choice" ]]; then
        case "$cmd" in
            FUZZEL)
                fuzzel
                ;;
            TERM:*)
                terminal "${cmd#TERM:}"
                ;;
            GUI:*)
                uwsm-app -- "${cmd#GUI:}"
                ;;
            *)
                eval "$cmd"
                ;;
        esac
        exit 0
    fi
done
