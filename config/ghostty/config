#vim: set ft=conf:
font-family = JetBrains Mono
font-size = 15

theme = light:Catppuccin Latte,dark:Ayu

background-opacity = 0.8
# macOS 26 glass effect; falls back to regular blur elsewhere.
# background-blur = macos-glass-clear
background-blur = 80
macos-titlebar-style = transparent
window-padding-x = 12
window-padding-y = 12
# window-decoration = auto
# macos-titlebar-style = hidden

# fix for opencode https://github.com/anomalyco/opencode/issues/4046#issuecomment-3717801839
# disabled because it breaks pi/tmux Shift+Enter handling
# keybind = shift+enter=text:\x1b\r
